<% content_for :title, "Pedido ##{@order["id"]} — LifeHub Admin" %>

<%= link_to "← Voltar a Pedidos", orders_path, class: "text-sm text-slate-500 hover:text-slate-900" %>
<h1 class="text-2xl font-semibold text-slate-900 mt-2 mb-6">Pedido #<%= @order["id"] %></h1>

<div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
  <div class="bg-white rounded-lg shadow-sm border border-slate-200 p-5">
    <h2 class="text-sm font-semibold text-slate-700 mb-3">Detalhes do pedido</h2>
    <dl class="space-y-2 text-sm">
      <div class="flex justify-between"><dt class="text-slate-500">Estado</dt><dd class="text-slate-900"><%= @order["status"] %></dd></div>
      <div class="flex justify-between"><dt class="text-slate-500">Pagamento</dt><dd class="text-slate-900"><%= @order["payment_status"] %></dd></div>
      <div class="flex justify-between"><dt class="text-slate-500">Total</dt><dd class="text-slate-900">Kz <%= number_with_delimiter(@order["total_amount"]) %></dd></div>
      <div class="flex justify-between"><dt class="text-slate-500">Taxa de entrega</dt><dd class="text-slate-900">Kz <%= number_with_delimiter(@order["delivery_fee"]) %></dd></div>
      <div class="flex justify-between"><dt class="text-slate-500">Morada de entrega</dt><dd class="text-slate-900"><%= @order["delivery_address"] %></dd></div>
    </dl>

    <h3 class="text-sm font-semibold text-slate-700 mt-5 mb-2">Itens</h3>
    <table class="w-full text-sm">
      <tbody>
        <% (@order["items"] || []).each do |item| %>
          <tr class="border-t border-slate-100">
            <td class="py-2 text-slate-500">Produto #<%= item["product_id"] %></td>
            <td class="py-2 text-slate-500">x<%= item["quantity"] %></td>
            <td class="py-2 text-right text-slate-900">Kz <%= number_with_delimiter(item["subtotal"]) %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>

  <div class="bg-white rounded-lg shadow-sm border border-slate-200 p-5">
    <h2 class="text-sm font-semibold text-slate-700 mb-3">Pagamento</h2>

    <% if @payment %>
      <dl class="space-y-2 text-sm mb-4">
        <div class="flex justify-between"><dt class="text-slate-500">Estado</dt><dd class="text-slate-900"><%= @payment["status"] %></dd></div>
        <div class="flex justify-between"><dt class="text-slate-500">Fornecedor</dt><dd class="text-slate-900"><%= @payment["provider"] %></dd></div>
        <div class="flex justify-between"><dt class="text-slate-500">Referência</dt><dd class="text-slate-900"><%= @payment["gateway_reference"] %></dd></div>
        <div class="flex justify-between"><dt class="text-slate-500">Valor</dt><dd class="text-slate-900">Kz <%= number_with_delimiter(@payment["amount"]) %></dd></div>
      </dl>

      <% if @payment["status"] == "approved" %>
        <%= form_with url: refund_payment_path(@payment["id"]), method: :post, class: "flex gap-2" do %>
          <input type="text" name="reason" placeholder="Motivo do reembolso" class="flex-1 rounded-md border-slate-300 shadow-sm text-sm" />
          <button type="submit" class="rounded-md bg-red-600 px-4 py-2 text-sm font-medium text-white hover:bg-red-500">Reembolsar</button>
        <% end %>
      <% end %>

      <h3 class="text-sm font-semibold text-slate-700 mt-5 mb-2">Histórico de tentativas</h3>
      <table class="w-full text-sm">
        <tbody>
          <% (@payment["transactions"] || []).each do |transaction| %>
            <tr class="border-t border-slate-100">
              <td class="py-2 text-slate-500"><%= transaction["created_at"] %></td>
              <td class="py-2 text-slate-900"><%= transaction["status"] %></td>
              <td class="py-2 text-right text-slate-500"><%= transaction["reference"] %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
    <% else %>
      <p class="text-sm text-slate-500">Ainda não foi iniciado nenhum pagamento para este pedido.</p>
    <% end %>
  </div>
</div>
