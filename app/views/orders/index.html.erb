<% content_for :title, "Pedidos — LifeHub Admin" %>

<h1 class="text-2xl font-semibold text-slate-900 mb-6">Pedidos & Pagamentos</h1>

<div class="bg-white rounded-lg shadow-sm border border-slate-200 overflow-hidden">
  <table class="w-full text-sm">
    <thead class="bg-slate-50 text-left text-slate-500">
      <tr>
        <th class="px-4 py-3 font-medium">#</th>
        <th class="px-4 py-3 font-medium">Estado</th>
        <th class="px-4 py-3 font-medium">Pagamento</th>
        <th class="px-4 py-3 font-medium">Total (Kz)</th>
        <th class="px-4 py-3 font-medium">Criado em</th>
        <th class="px-4 py-3"></th>
      </tr>
    </thead>
    <tbody>
      <% @orders.each do |order| %>
        <tr class="border-t border-slate-100">
          <td class="px-4 py-3 font-medium text-slate-900">#<%= order["id"] %></td>
          <td class="px-4 py-3"><%= order["status"] %></td>
          <td class="px-4 py-3"><%= order["payment_status"] %></td>
          <td class="px-4 py-3 text-slate-500"><%= number_with_delimiter(order["total_amount"]) %></td>
          <td class="px-4 py-3 text-slate-500"><%= order["created_at"] %></td>
          <td class="px-4 py-3 text-right">
            <%= link_to "Ver", order_path(order["id"]), class: "text-slate-700 hover:text-slate-900 font-medium" %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>

<p class="text-sm text-slate-500 mt-3"><%= @meta["count"] %> pedido(s) encontrados.</p>
