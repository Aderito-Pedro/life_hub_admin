<% content_for :title, "Dashboard — LifeHub Admin" %>

<h1 class="text-2xl font-semibold text-slate-900 mb-6">Dashboard</h1>

<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 mb-8">
  <div class="bg-white rounded-lg shadow-sm border border-slate-200 p-5">
    <div class="text-sm text-slate-500">Utilizadores</div>
    <div class="text-2xl font-semibold text-slate-900 mt-1"><%= @stats.dig("users", "total") %></div>
  </div>

  <div class="bg-white rounded-lg shadow-sm border border-slate-200 p-5">
    <div class="text-sm text-slate-500">Pedidos</div>
    <div class="text-2xl font-semibold text-slate-900 mt-1"><%= @stats.dig("orders", "total") %></div>
  </div>

  <div class="bg-white rounded-lg shadow-sm border border-slate-200 p-5">
    <div class="text-sm text-slate-500">Pagamentos aprovados</div>
    <div class="text-2xl font-semibold text-slate-900 mt-1"><%= number_to_currency(@stats.dig("payments", "approved_total"), unit: "Kz ", separator: ",", delimiter: ".") %></div>
    <div class="text-xs text-slate-400 mt-1"><%= @stats.dig("payments", "pending_count") %> pendentes</div>
  </div>

  <div class="bg-white rounded-lg shadow-sm border border-slate-200 p-5">
    <div class="text-sm text-slate-500">Eventos de auditoria (24h)</div>
    <div class="text-2xl font-semibold text-slate-900 mt-1"><%= @stats.dig("audit", "last_24h_count") %></div>
  </div>
</div>

<div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
  <div class="bg-white rounded-lg shadow-sm border border-slate-200 p-5">
    <h2 class="text-sm font-semibold text-slate-700 mb-3">Utilizadores por perfil</h2>
    <dl class="space-y-1 text-sm">
      <% (@stats.dig("users", "by_role") || {}).each do |role, count| %>
        <div class="flex justify-between">
          <dt class="text-slate-500"><%= role %></dt>
          <dd class="font-medium text-slate-900"><%= count %></dd>
        </div>
      <% end %>
    </dl>
  </div>

  <div class="bg-white rounded-lg shadow-sm border border-slate-200 p-5">
    <h2 class="text-sm font-semibold text-slate-700 mb-3">Pedidos por estado</h2>
    <dl class="space-y-1 text-sm">
      <% (@stats.dig("orders", "by_status") || {}).each do |status, count| %>
        <div class="flex justify-between">
          <dt class="text-slate-500"><%= status %></dt>
          <dd class="font-medium text-slate-900"><%= count %></dd>
        </div>
      <% end %>
    </dl>
  </div>
</div>

<div class="bg-white rounded-lg shadow-sm border border-slate-200 p-5 mt-6">
  <h2 class="text-sm font-semibold text-slate-700 mb-3">Auditoria recente</h2>
  <table class="w-full text-sm">
    <tbody>
      <% (@stats.dig("audit", "recent") || []).each do |log| %>
        <tr class="border-t border-slate-100">
          <td class="py-2 text-slate-500"><%= log["created_at"] %></td>
          <td class="py-2 font-medium text-slate-900"><%= log["action"] %></td>
          <td class="py-2 text-slate-500">utilizador #<%= log["user_id"] %></td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>
