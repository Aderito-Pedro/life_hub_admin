<% content_for :title, "Produtos — LifeHub Admin" %>

<div class="flex items-center justify-between mb-6">
  <h1 class="text-2xl font-semibold text-slate-900">Produtos</h1>
  <%= link_to "Novo produto", new_product_path, class: "rounded-md bg-slate-900 px-4 py-2 text-sm font-medium text-white hover:bg-slate-800" %>
</div>

<%= form_with url: products_path, method: :get, class: "flex flex-wrap gap-3 mb-6" do %>
  <input type="text" name="q" value="<%= params[:q] %>" placeholder="Pesquisar por nome"
         class="rounded-md border-slate-300 shadow-sm text-sm w-64" />
  <button type="submit" class="rounded-md bg-slate-900 px-4 py-2 text-sm font-medium text-white hover:bg-slate-800">Filtrar</button>
<% end %>

<div class="bg-white rounded-lg shadow-sm border border-slate-200 overflow-hidden">
  <table class="w-full text-sm">
    <thead class="bg-slate-50 text-left text-slate-500">
      <tr>
        <th class="px-4 py-3 font-medium">Nome</th>
        <th class="px-4 py-3 font-medium">Preço (Kz)</th>
        <th class="px-4 py-3 font-medium">Stock</th>
        <th class="px-4 py-3 font-medium">Publicado</th>
        <th class="px-4 py-3"></th>
      </tr>
    </thead>
    <tbody>
      <% @products.each do |product| %>
        <tr class="border-t border-slate-100">
          <td class="px-4 py-3 font-medium text-slate-900"><%= product["name"] %></td>
          <td class="px-4 py-3 text-slate-500"><%= number_with_delimiter(product["price"]) %></td>
          <td class="px-4 py-3"><%= product["stock_quantity"] %></td>
          <td class="px-4 py-3"><%= product["published"] ? "sim" : "não" %></td>
          <td class="px-4 py-3 text-right">
            <%= link_to "Editar", edit_product_path(product["id"]), class: "text-slate-700 hover:text-slate-900 font-medium" %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>

<p class="text-sm text-slate-500 mt-3"><%= @meta["count"] %> produto(s) encontrados.</p>
