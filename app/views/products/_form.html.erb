<%= form_with url: url, method: method, class: "bg-white rounded-lg shadow-sm border border-slate-200 p-6 space-y-4 max-w-lg" do |form| %>
  <div>
    <label class="block text-sm font-medium text-slate-700">Nome</label>
    <input type="text" name="product[name]" value="<%= product["name"] %>" required
           class="mt-1 block w-full rounded-md border-slate-300 shadow-sm sm:text-sm" />
  </div>

  <div>
    <label class="block text-sm font-medium text-slate-700">Categoria</label>
    <select name="product[category_id]" required class="mt-1 block w-full rounded-md border-slate-300 shadow-sm sm:text-sm">
      <% @categories.each do |category| %>
        <option value="<%= category["id"] %>" <%= "selected" if product["category_id"].to_s == category["id"].to_s %>><%= category["name"] %></option>
      <% end %>
    </select>
  </div>

  <div>
    <label class="block text-sm font-medium text-slate-700">Preço (Kz)</label>
    <input type="number" step="0.01" name="product[price]" value="<%= product["price"] %>" required
           class="mt-1 block w-full rounded-md border-slate-300 shadow-sm sm:text-sm" />
  </div>

  <div>
    <label class="block text-sm font-medium text-slate-700">Quantidade em stock</label>
    <input type="number" name="product[stock_quantity]" value="<%= product["stock_quantity"] %>"
           class="mt-1 block w-full rounded-md border-slate-300 shadow-sm sm:text-sm" />
  </div>

  <div>
    <label class="block text-sm font-medium text-slate-700">Descrição</label>
    <textarea name="product[description]" rows="3"
              class="mt-1 block w-full rounded-md border-slate-300 shadow-sm sm:text-sm"><%= product["description"] %></textarea>
  </div>

  <div class="flex items-center gap-2">
    <input type="hidden" name="product[published]" value="0" />
    <input type="checkbox" name="product[published]" value="1" id="product_published" <%= "checked" if product["published"] != false %>
           class="rounded border-slate-300" />
    <label for="product_published" class="text-sm text-slate-700">Publicado</label>
  </div>

  <div class="flex items-center gap-2">
    <input type="hidden" name="product[active]" value="0" />
    <input type="checkbox" name="product[active]" value="1" id="product_active" <%= "checked" if product["active"] != false %>
           class="rounded border-slate-300" />
    <label for="product_active" class="text-sm text-slate-700">Activo</label>
  </div>

  <%= form.submit "Guardar", class: "rounded-md bg-slate-900 px-4 py-2 text-sm font-medium text-white hover:bg-slate-800 cursor-pointer" %>
<% end %>
