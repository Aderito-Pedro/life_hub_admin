<% content_for :title, "Auditoria — LifeHub Admin" %>

<h1 class="text-2xl font-semibold text-slate-900 mb-6">Auditoria</h1>

<%= form_with url: audit_logs_path, method: :get, class: "flex flex-wrap gap-3 mb-6" do %>
  <input type="text" name="event" value="<%= params[:event] %>" placeholder="Tipo de evento (ex. auth.login)"
         class="rounded-md border-slate-300 shadow-sm text-sm w-64" />
  <input type="text" name="user_id" value="<%= params[:user_id] %>" placeholder="ID do utilizador"
         class="rounded-md border-slate-300 shadow-sm text-sm w-40" />
  <button type="submit" class="rounded-md bg-slate-900 px-4 py-2 text-sm font-medium text-white hover:bg-slate-800">Filtrar</button>
<% end %>

<div class="bg-white rounded-lg shadow-sm border border-slate-200 overflow-hidden">
  <table class="w-full text-sm">
    <thead class="bg-slate-50 text-left text-slate-500">
      <tr>
        <th class="px-4 py-3 font-medium">Data</th>
        <th class="px-4 py-3 font-medium">Evento</th>
        <th class="px-4 py-3 font-medium">Utilizador</th>
        <th class="px-4 py-3 font-medium">Registo</th>
        <th class="px-4 py-3 font-medium">IP</th>
      </tr>
    </thead>
    <tbody>
      <% @audit_logs.each do |log| %>
        <tr class="border-t border-slate-100">
          <td class="px-4 py-3 text-slate-500"><%= log["created_at"] %></td>
          <td class="px-4 py-3 font-medium text-slate-900"><%= log["action"] %></td>
          <td class="px-4 py-3 text-slate-500"><%= log["user_id"] ? "##{log['user_id']}" : "—" %></td>
          <td class="px-4 py-3 text-slate-500"><%= [ log["auditable_type"], log["auditable_id"] ].compact.join(" #") %></td>
          <td class="px-4 py-3 text-slate-500"><%= log["ip_address"] %></td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>

<p class="text-sm text-slate-500 mt-3"><%= @meta["count"] %> evento(s) encontrados.</p>
