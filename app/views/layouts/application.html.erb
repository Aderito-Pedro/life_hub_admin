<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "LifeHub Admin" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="LifeHub Admin">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="bg-slate-50 text-slate-900">
    <div class="min-h-screen flex">
      <aside class="w-64 shrink-0 bg-slate-900 text-slate-200 flex flex-col">
        <div class="px-6 py-5 text-lg font-semibold text-white border-b border-slate-800">
          LifeHub Angola
          <div class="text-xs font-normal text-slate-400">Painel Administrativo</div>
        </div>

        <nav class="flex-1 px-3 py-4 space-y-1">
          <%= render "layouts/nav_link", path: dashboard_path, label: "Dashboard" %>
          <%= render "layouts/nav_link", path: users_path, label: "Utilizadores" %>
          <%= render "layouts/nav_link", path: categories_path, label: "Categorias" %>
          <%= render "layouts/nav_link", path: products_path, label: "Produtos" %>
          <%= render "layouts/nav_link", path: orders_path, label: "Pedidos & Pagamentos" %>
          <%= render "layouts/nav_link", path: audit_logs_path, label: "Auditoria" %>
        </nav>

        <% if current_staff %>
          <div class="px-6 py-4 border-t border-slate-800 text-sm">
            <div class="font-medium text-white"><%= current_staff["full_name"] %></div>
            <div class="text-slate-400"><%= current_staff["role"] %></div>
            <%= button_to "Terminar sessão", logout_path, method: :delete,
                  class: "mt-3 w-full text-left text-slate-300 hover:text-white text-sm" %>
          </div>
        <% end %>
      </aside>

      <div class="flex-1 flex flex-col min-w-0">
        <main class="flex-1 p-8">
          <% if notice %>
            <div class="mb-4 rounded-md bg-emerald-50 px-4 py-3 text-sm text-emerald-800 border border-emerald-200"><%= notice %></div>
          <% end %>
          <% if alert %>
            <div class="mb-4 rounded-md bg-red-50 px-4 py-3 text-sm text-red-800 border border-red-200"><%= alert %></div>
          <% end %>

          <%= yield %>
        </main>
      </div>
    </div>
  </body>
</html>
