<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "LifeHub Admin" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <link rel="icon" href="/icon.png" type="image/png">
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="bg-slate-900 min-h-screen flex items-center justify-center">
    <div class="w-full max-w-sm">
      <% if notice %>
        <div class="mb-4 rounded-md bg-emerald-50 px-4 py-3 text-sm text-emerald-800 border border-emerald-200"><%= notice %></div>
      <% end %>
      <% if alert %>
        <div class="mb-4 rounded-md bg-red-50 px-4 py-3 text-sm text-red-800 border border-red-200"><%= alert %></div>
      <% end %>

      <%= yield %>
    </div>
  </body>
</html>
